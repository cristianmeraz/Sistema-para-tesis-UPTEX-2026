/**
 * 💬 SISTEMA PREMIUM DE COMENTARIOS
 * Gestión completa de comentarios con auto-refresh y validaciones
 */

const CommentSystem = (() => {
    const config = {
        pollInterval: 5000, // 5 segundos
        maxCharacters: 2000,
        minCharacters: 5,
        apiBaseUrl: '/w'  // Prefijo /w/ para rutas web (evita conflicto con /api/ de Sanctum)
    };

    let pollTimer = null;
    let lastCommentCount = 0;

    // ============= INICIALIZACIÓN =============
    const init = () => {
        // Opción 1: Obtener del contenedor
        let ticketId = document.querySelector('[data-ticket-id]')?.getAttribute('data-ticket-id');
        
        // Opción 2: Obtener del formulario como respaldo
        if (!ticketId) {
            ticketId = document.querySelector('[data-comment-form]')?.getAttribute('data-ticket-id');
        }
        
        // Opción 3: Obtener de la URL
        if (!ticketId) {
            const match = window.location.pathname.match(/\/tickets\/(\d+)/);
            ticketId = match ? match[1] : null;
        }
        
        console.log('🆔 Ticket ID obtenido:', ticketId);
        if (!ticketId) {
            console.error('❌ No se encontró ticket ID. El sistema no puede funcionar sin él.');
            showError('Error: No se pudo identificar el ticket. Recarga la página.');
            return;
        }

        setupFormHandlers(ticketId);
        setupCharCounter();
        setupEditHandlers(ticketId);
        startAutoPolling(ticketId);
    };

    // ============= MANEJADORES DE FORMULARIO =============
    const setupFormHandlers = (ticketId) => {
        const form = document.querySelector('[data-comment-form]');
        const submitBtn = document.querySelector('[data-btn-submit-comment]');
        
        if (!form) {
            console.warn('⚠️ Formulario de comentarios no encontrado. Recarga la página.');
            return;
        }

        if (!submitBtn) {
            console.warn('⚠️ Botón de envío no encontrado. Recarga la página.');
            return;
        }

        console.log('✅ Formulario y botón encontrados, configurando handlers');
        
        // Escuchar click en el botón de envío
        submitBtn.addEventListener('click', async (e) => {
            console.log('🖱️ Click en botón de envío capturado');
            e.preventDefault();
            e.stopPropagation();
            await submitComment(ticketId, form);
        });
        
        // Respaldo: Escuchar submit del formulario por si se presiona Enter
        form.addEventListener('submit', (e) => {
            console.log('📤 Evento submit del formulario capturado');
            e.preventDefault();
            e.stopPropagation();
            submitComment(ticketId, form);
        });
    };

    // ============= ENVIAR COMENTARIO =============
    const submitComment = async (ticketId, form) => {
        const textarea = form.querySelector('textarea[name="contenido"]');
        const submitBtn = document.querySelector('[data-btn-submit-comment]');
        
        if (!textarea || !submitBtn) {
            console.error('textarea:', textarea, 'submitBtn:', submitBtn);
            showError('Formulario incompleto');
            return;
        }

        const content = textarea.value.trim();

        // Validación
        if (!validateComment(content)) return;

        // Deshabilitar botón
        submitBtn.disabled = true;
        const originalText = submitBtn.innerHTML;
        submitBtn.innerHTML = '<i class="bi bi-hourglass-split me-1"></i>Guardando...';

        try {
            const endpoint = `${config.apiBaseUrl}/tickets/${ticketId}/comentarios`;
            console.log('Enviando POST a:', endpoint);
            
            const response = await fetch(endpoint, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-CSRF-TOKEN': document.querySelector('[name="_token"]')?.value || '',
                    'Accept': 'application/json'
                },
                body: JSON.stringify({ contenido: content })
            });

            console.log('Respuesta status:', response.status);
            const data = await response.json();
            console.log('Data:', data);

            if (!response.ok) {
                showError(data.message || data.error || 'Error al guardar comentario');
                return;
            }

            // Éxito
            showSuccess('Comentario guardado exitosamente ✓');
            form.reset();
            updateCharCounter();
            
            // Actualizar comentarios
            await refreshComments(ticketId);

        } catch (error) {
            console.error('Error completo:', error);
            showError('Error de conexión: ' + error.message);
        } finally {
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalText;
        }
    };

    // ============= VALIDACIÓN =============
    const validateComment = (content) => {
        if (content.length < config.minCharacters) {
            showError(`Mínimo ${config.minCharacters} caracteres`);
            return false;
        }
        if (content.length > config.maxCharacters) {
            showError(`Máximo ${config.maxCharacters} caracteres`);
            return false;
        }
        return true;
    };

    // ============= CONTADOR DE CARACTERES =============
    const setupCharCounter = () => {
        const textarea = document.querySelector('[data-comment-form] textarea[name="contenido"]');
        if (!textarea) return;

        textarea.addEventListener('input', updateCharCounter);
        updateCharCounter();
    };

    const updateCharCounter = () => {
        const textarea = document.querySelector('[data-comment-form] textarea[name="contenido"]');
        const counter = document.querySelector('[data-char-count]');
        
        if (!textarea || !counter) return;

        const length = textarea.value.length;
        counter.textContent = `${length}/${config.maxCharacters}`;
        counter.classList.toggle('warning', length > config.maxCharacters * 0.9);
    };

    // ============= EDITAR Y ELIMINAR COMENTARIOS =============
    const setupEditHandlers = (ticketId) => {
        document.addEventListener('click', (e) => {
            // Botón: Editar
            if (e.target.closest('[data-btn-edit-comment]')) {
                const commentId = e.target.closest('[data-btn-edit-comment]')?.dataset.commentId;
                const content = e.target.closest('.comment-item')?.querySelector('.comment-content')?.textContent;
                openEditModal(ticketId, commentId, content);
            }

            // Botón: Eliminar
            if (e.target.closest('[data-btn-delete-comment]')) {
                const commentId = e.target.closest('[data-btn-delete-comment]')?.dataset.commentId;
                if (confirm('¿Estás seguro de que quieres eliminar este comentario?')) {
                    deleteComment(ticketId, commentId);
                }
            }
        });
    };

    const openEditModal = (ticketId, commentId, content) => {
        const modal = new bootstrap.Modal(document.getElementById('editCommentModal'));
        const textarea = document.querySelector('[data-edit-comment-textarea]');
        textarea.value = content;
        textarea.focus();
        modal.show();

        // Guardar cambios al submit
        const form = document.querySelector('[data-edit-comment-form]');
        form.onsubmit = async (e) => {
            e.preventDefault();
            await submitEditComment(ticketId, commentId, form, modal);
        };
    };

    const submitEditComment = async (ticketId, commentId, form, modal) => {
        const textarea = form.querySelector('[data-edit-comment-textarea]');
        const submitBtn = form.querySelector('button[type="submit"]');
        const content = textarea.value.trim();

        if (!validateComment(content)) return;

        submitBtn.disabled = true;
        const originalText = submitBtn.innerHTML;
        submitBtn.innerHTML = '<i class="bi bi-hourglass-split me-1"></i>Guardando...';

        try {
            const response = await fetch(`${config.apiBaseUrl}/tickets/${ticketId}/comentarios/${commentId}`, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json',
                    'X-CSRF-TOKEN': document.querySelector('[name="_token"]')?.value || '',
                    'Accept': 'application/json'
                },
                body: JSON.stringify({ contenido: content })
            });

            const data = await response.json();

            if (!response.ok) {
                showError(data.error || 'Error al actualizar comentario');
                return;
            }

            showSuccess('Comentario actualizado exitosamente');
            modal.hide();
            await refreshComments(ticketId);

        } catch (error) {
            console.error('Error:', error);
            showError('Error al actualizar comentario');
        } finally {
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalText;
        }
    };

    const deleteComment = async (ticketId, commentId) => {
        try {
            const response = await fetch(`${config.apiBaseUrl}/tickets/${ticketId}/comentarios/${commentId}`, {
                method: 'DELETE',
                headers: {
                    'X-CSRF-TOKEN': document.querySelector('[name="_token"]')?.value || '',
                    'Accept': 'application/json'
                }
            });

            const data = await response.json();

            if (!response.ok) {
                showError(data.error || 'Error al eliminar comentario');
                return;
            }

            showSuccess('Comentario eliminado exitosamente');
            await refreshComments(ticketId);

        } catch (error) {
            console.error('Error:', error);
            showError('Error al eliminar comentario');
        }
    };

    // ============= AUTO-REFRESH DE COMENTARIOS =============
    const startAutoPolling = (ticketId) => {
        refreshComments(ticketId);
        pollTimer = setInterval(() => refreshComments(ticketId), config.pollInterval);
    };

    const stopAutoPolling = () => {
        if (pollTimer) clearInterval(pollTimer);
    };

    const refreshComments = async (ticketId) => {
        try {
            const response = await fetch(`${config.apiBaseUrl}/tickets/${ticketId}/comentarios`, {
                headers: {
                    'Accept': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                }
            });

            if (!response.ok) return;

            const data = await response.json();
            updateCommentsDOM(data.comentarios);

            // Notificar si hay comentarios nuevos
            if (data.comentarios.length > lastCommentCount) {
                lastCommentCount = data.comentarios.length;
                playNotificationSound();
            }

        } catch (error) {
            console.error('Error refrescando comentarios:', error);
        }
    };

    // ============= ACTUALIZAR DOM =============
    const updateCommentsDOM = (comentarios) => {
        const container = document.querySelector('[data-comentarios-container]');
        if (!container) return;

        // Generar HTML de comentarios
        const html = comentarios.length > 0
            ? comentarios.map(comment => createCommentHTML(comment)).join('')
            : '<div class="no-comments"><div class="no-comments-icon">💬</div><p class="no-comments-text">No hay comentarios aún.</p></div>';

        container.innerHTML = html;

        // Actualizar contador
        const countBadge = document.querySelector('.comments-count');
        if (countBadge) countBadge.textContent = comentarios.length;

        // Animar entrada
        container.querySelectorAll('.comment-item').forEach(el => {
            el.style.animation = 'slideIn 0.3s ease';
        });
    };

    const createCommentHTML = (comment) => {
        const user = comment.usuario || {};
        const role = user.rol?.nombre || 'Usuario';
        const initials = getInitials(user.nombre, user.apellido);
        const roleClass = role.includes('Técnico') ? 'tecnico' : role.includes('Admin') ? 'admin' : 'usuario';
        const borderColor = roleClass === 'admin' ? '#10B981' : roleClass === 'tecnico' ? '#3b82f6' : '#f59e0b';
        
        // Botones de acción
        const actionButtons = `
            <div class="comment-actions" style="display: flex; gap: 0.5rem; margin-top: 0.5rem;">
                <button type="button" 
                        class="btn btn-sm btn-outline-primary"
                        data-btn-edit-comment
                        data-comment-id="${comment.id_comentario}"
                        title="Editar comentario">
                    <i class="bi bi-pencil"></i> Editar
                </button>
                <button type="button" 
                        class="btn btn-sm btn-outline-danger"
                        data-btn-delete-comment
                        data-comment-id="${comment.id_comentario}"
                        title="Eliminar comentario">
                    <i class="bi bi-trash"></i> Eliminar
                </button>
            </div>
        `;
        
        return `
            <div class="comment-item comment-item-${roleClass}" data-comment-id="${comment.id_comentario}">
                <div class="comment-header">
                    <div class="comment-user-info">
                        <div class="comment-avatar" style="background: linear-gradient(135deg, ${borderColor}dd, ${borderColor})">${initials}</div>
                        <div>
                            <div class="comment-username">${user.nombre || 'Anónimo'} ${user.apellido || ''}</div>
                            <span class="comment-role-badge">
                                ${getRoleIcon(roleClass)} ${role}
                            </span>
                        </div>
                    </div>
                    <div class="comment-meta">
                        <span class="comment-date" title="${comment.created_at}">
                            ${formatDate(comment.created_at)}
                        </span>
                    </div>
                </div>
                <div class="comment-content">${escapeHtml(comment.contenido)}</div>
                ${actionButtons}
            </div>
        `;
    };

    const getInitials = (nombre, apellido) => {
        const first = (nombre || '').charAt(0).toUpperCase();
        const second = (apellido || '').charAt(0).toUpperCase();
        return first + second || 'U';
    };

    const getRoleIcon = (role) => {
        const icons = {
            'admin': '<i class="bi bi-shield-lock"></i>',
            'tecnico': '<i class="bi bi-tools"></i>',
            'usuario': '<i class="bi bi-person-fill"></i>'
        };
        return icons[role] || icons['usuario'];
    };

    const escapeHtml = (text) => {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    };

    const formatDate = (dateString) => {
        const date = new Date(dateString);
        const now = new Date();
        const diff = now - date;
        const minutes = Math.floor(diff / 60000);
        const hours = Math.floor(minutes / 60);
        const days = Math.floor(hours / 24);

        if (minutes < 1) return 'Ahora';
        if (minutes < 60) return `Hace ${minutes}m`;
        if (hours < 24) return `Hace ${hours}h`;
        if (days < 7) return `Hace ${days}d`;
        
        return date.toLocaleDateString('es-MX', { day: '2-digit', month: '2-digit', year: '2-digit' });
    };

    // ============= NOTIFICACIONES =============
    const showSuccess = (message) => {
        showNotification(message, 'success');
    };

    const showError = (message) => {
        showNotification(message, 'error');
    };

    const showNotification = (message, type = 'info') => {
        const alertClass = type === 'success' ? 'alert-success' : type === 'error' ? 'alert-danger' : 'alert-info';
        const icon = type === 'success' ? '✓' : type === 'error' ? '✕' : 'ℹ';
        
        const alert = document.createElement('div');
        alert.className = `alert ${alertClass} alert-dismissible fade show`;
        alert.role = 'alert';
        alert.innerHTML = `
            <span>${icon} ${message}</span>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        `;
        
        const container = document.querySelector('.comments-section') || document.body;
        container.insertBefore(alert, container.firstChild);
        
        setTimeout(() => alert.remove(), 4000);
    };

    const playNotificationSound = () => {
        const audio = new Audio('data:audio/wav;base64,UklGRiYAAABXQVZFZm10IBAAAAABAAEAQB8AAAB9AAACABAAZGF0YQIAAAAAAA==');
        audio.play().catch(() => {}); // Silenciar si no está permitido
    };

    // ============= LIMPIEZA =============
    window.addEventListener('beforeunload', () => stopAutoPolling());

    return {
        init,
        refreshComments,
        destroy: stopAutoPolling
    };
})();

// Iniciar cuando el DOM esté listo
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', CommentSystem.init);
} else {
    // Si el DOM ya está listo (script cargado en defer), ejecutar inmediatamente
    CommentSystem.init();
}
